{
  "name": "douyin-video-download",
  "version": "1.0.1",
  "description": "A Tauri desktop app for monitoring Douyin users and downloading videos.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tauri": "tauri",
    "build": "vite build",
    "build:web": "vite build",
    "test:extension": "node --test chrome-extension/test-service-worker.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "extension:init-key": "node scripts/init-extension-key.mjs",
    "extension:pack": "node scripts/pack-extension.mjs",
    "verify": "pnpm run typecheck && pnpm run test:extension && cargo test --manifest-path src-tauri/Cargo.toml",
    "package:windows": "pnpm run verify && pnpm tauri build",
    "package:macos": "pnpm run verify && pnpm tauri build",
    "package:macos:universal": "pnpm run verify && pnpm tauri build --target universal-apple-darwin",
    "package:linux": "pnpm run verify && pnpm tauri build",
    "release": "pnpm run verify && pnpm tauri build && pnpm run extension:pack"
  },
  "engines": {
    "node": ">=v22.13"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "^1.169.2",
    "@tauri-apps/api": "^2.9.0",
    "@types/node": "^25.6.2",
    "@videojs/react": "^10.0.0-beta.23",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.167.35",
    "@tauri-apps/cli": "^2.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "crx3": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
