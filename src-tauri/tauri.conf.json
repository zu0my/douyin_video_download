{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Douyin Archive",
  "version": "0.1.0",
  "identifier": "com.local.douyin-archive",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist-ui"
  },
  "app": {
    "windows": [
      {
        "title": "Douyin Archive",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$LOCALDATA/douyin-video-download/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Douyin Archive",
    "category": "Utility",
    "shortDescription": "本地监控和归档抖音作品。",
    "longDescription": "Douyin Archive 是一个用于本地监控、下载和播放抖音作品的桌面应用。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
